# ── Notion API ─────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations 에서 Internal Integration Token 발급
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID
# https://www.notion.so/imweb/09870e1112ce83098f628118b6ba9bb3 → 09870e1112ce83098f628118b6ba9bb3
NOTION_DATABASE_ID=09870e1112ce83098f628118b6ba9bb3

# ── GitHub Pages 배포 ──────────────────────────────────────────────────────
# 프로젝트 페이지 (https://imweb-tech.github.io/imweb_techblog) 로 배포할 때만 true
GITHUB_PAGES=false
BASE_PATH=/imweb_techblog

# ── 분석 / 검색 도구 (선택) ─────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MEASUREMENT_ID=
